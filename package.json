{
  "name": "line-ferry",
  "displayName": "Line Ferry",
  "description": "Send the current line to the active terminal without executing",
  "version": "0.0.2",
  "publisher": "tsukamoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsukamoto/line-ferry"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lineFerry.send",
        "title": "Line Ferry: Send Line to Terminal"
      },
      {
        "command": "lineFerry.sendAndFocus",
        "title": "Line Ferry: Send Line to Terminal and Focus"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+enter",
        "command": "lineFerry.send",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+alt+enter",
        "command": "lineFerry.sendAndFocus",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
